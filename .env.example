# B787 Calculator — local environment template.
# Copy to .env.local (which is gitignored) and fill in real values.
# NEVER commit a populated copy of this file.

# Expo Personal Access Token (https://expo.dev/accounts/[username]/settings/access-tokens)
# Used by EAS CLI for builds and submits.
EXPO_TOKEN=

# Apple credentials — used by EAS Submit / EAS CLI when prompted.
# Apple ID email (App Store Connect login).
APPLE_ID=

# Apple Developer Team ID (10-char alphanumeric, public — already in eas.json,
# but kept here for parity / scripts).
APPLE_TEAM_ID=

# App Store Connect App ID (numeric, from App Store Connect → App Information → Apple ID).
ASC_APP_ID=

# App Store Connect API Key — preferred over Apple ID + password for non-interactive submits.
# Generated in App Store Connect → Users and Access → Keys → App Store Connect API.
# The .p8 file should be stored separately (1Password / encrypted volume), NEVER in this repo.
ASC_API_KEY_ID=
ASC_API_KEY_ISSUER_ID=
ASC_API_KEY_PATH=
