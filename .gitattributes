# Use LF for all text files (cross-platform consistency)
* text=auto eol=lf

# Force LF for shell scripts so they remain executable on Linux/macOS
*.sh text eol=lf
*.bash text eol=lf

# Force LF for husky hooks
.husky/* text eol=lf

# Treat as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ttf binary
*.otf binary
*.ico binary
*.icns binary
*.p12 binary
*.p8 binary
